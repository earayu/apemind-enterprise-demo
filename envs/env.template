# IMPORTANT (proxy hygiene): if your shell exports ``HTTP_PROXY`` /
# ``HTTPS_PROXY`` (e.g. for outbound LLM / web access), you MUST also
# export ``NO_PROXY`` (and lowercase ``no_proxy``) so localhost-bound
# requests bypass the proxy. The ``httpx``-based clients ApeRAG uses
# for Qdrant / Postgres / Redis / Elasticsearch / Object Store all
# default to ``trust_env=True``; without ``NO_PROXY`` they route
# ``http://127.0.0.1:6333`` through the proxy and the local proxy
# (polipo / privoxy / etc.) typically RST's localhost-to-localhost
# requests, surfacing as ``qdrant_client.http.exceptions.
# ResponseHandlingException: Server disconnected without sending a
# response`` and a vector index FAILED row.
#
# MinerU note (mainland China deployments): mineru.net is directly
# reachable without a proxy, but Python-requests times out when routed
# through a local CONNECT proxy (e.g. Privoxy).  Include ``mineru.net``
# in NO_PROXY so MinerU connects directly while LLM APIs (OpenRouter,
# etc.) still use the proxy for geo-restricted routes.
#
# Recommended setting:
#   NO_PROXY=mineru.net,localhost,127.0.0.1,::1
#   no_proxy=mineru.net,localhost,127.0.0.1,::1
#
# Uncomment + adjust the next two lines if your machine has shell
# proxy variables in scope when ``set -a && source .env`` runs.
# NO_PROXY=mineru.net,localhost,127.0.0.1,::1
# no_proxy=mineru.net,localhost,127.0.0.1,::1

# MetaDB
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Optional full database URL override. Leave empty to derive from the
# POSTGRES_* fields above.
DATABASE_URL=

# Database Connection Pool Settings
# Adjust these values based on your server resources and expected load
DB_POOL_SIZE=20              # Base connection pool size
DB_POOL_MAX_OVERFLOW=40      # Maximum overflow connections (total = pool_size + pool_max_overflow)
DB_POOL_TIMEOUT=60           # Connection timeout in seconds
DB_POOL_RECYCLE=3600         # Recycle connections after 1 hour (in seconds)
DB_POOL_PRE_PING=True        # Validate connections before use

# SSE pool (independent budget for streaming endpoints; isolates SSE
# generators from main API request pool so a long stream cannot starve
# regular requests). Mirrors the ``DB_POOL_*`` shape but applies only to
# routes wrapped with ``sse_engine_scope()``.
DB_SSE_POOL_SIZE=30
DB_SSE_POOL_MAX_OVERFLOW=60
DB_SSE_POOL_TIMEOUT=10
DB_SSE_POOL_RECYCLE=300

# Graph PG. Set ``GRAPH_DATABASE_URL`` to point graph_storage at a
# dedicated PostgreSQL cluster (independent of the metadata DB). When
# unset, graph_storage falls back to ``DATABASE_URL`` / the
# ``POSTGRES_*`` connection above. Standard delivery splits graph PG
# into its own cluster (see ``deploy/databases/postgresql-graph/``).
GRAPH_DATABASE_URL=
GRAPH_DB_POOL_SIZE=20
GRAPH_DB_POOL_MAX_OVERFLOW=40
GRAPH_DB_POOL_TIMEOUT=60
GRAPH_DB_POOL_RECYCLE=3600
GRAPH_DB_POOL_PRE_PING=True

# PG safety / observability params. Non-default values applied to every
# asyncpg connection by ``aperag.db.connect_args._asyncpg_connect_args()``
# regardless of which engine (main / SSE / graph) opens it. Tune these
# only if you know what you're doing — defaults match the SG production
# tunings shipped in round 2 P2-RD2-1.
#
# ``PG_STATEMENT_TIMEOUT_MS`` / ``PG_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS``
# are Pydantic ``int`` fields with default ``0`` (= disabled, no timeout).
# Leave at ``0`` to keep the upstream PostgreSQL default. Empty string
# fails Pydantic int parsing; comment out or set ``0`` to disable.
PG_APPLICATION_NAME=aperag
PG_STATEMENT_TIMEOUT_MS=0
PG_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=0
DB_PGBOUNCER_TRANSACTION_MODE=False

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=password

# Runtime Redis URLs. Leave empty to derive from REDIS_*:
# MEMORY_REDIS_URL -> db 1, INDEXING_QUEUE_REDIS_URL -> db 2,
# INDEXING_QUOTA_REDIS_URL -> db 3.
MEMORY_REDIS_URL=

# Indexing runtime
# async runs background indexing workers in the API process; inline indexes
# within the upload request and is intended for tiny single-process installs.
INDEXING_MODE=async
# Use inmemory for a single process. Docker/Kubernetes deployments should
# override this to redis.
INDEXING_QUEUE_BACKEND=inmemory
INDEXING_QUEUE_REDIS_URL=
INDEXING_METRICS_EMITTER=noop
# INDEXING_QUOTA_* drives the per-modality LLM cap backend in
# aperag.indexing.llm_quota (RFC indexing-refactor §4 hard-cut: the
# legacy tenant token-bucket layer was deleted; the env names were
# kept to preserve operator deployments). Multi-pod indexing-worker
# deployments must set INDEXING_QUOTA_BACKEND=redis so all worker
# pods share llm_inflight:<modality> / llm_cap:<modality> state.
INDEXING_QUOTA_BACKEND=inmemory
INDEXING_QUOTA_REDIS_URL=

# perf-audit-v1 §17.1 #2 (P3-9): reconciler / cleanup loop intervals.
# Defaults match prior module constants (30s / 300s). Tighten on
# high-churn-delete workloads or loosen on tier-1 single-machine to
# save DB scans.
INDEXING_RECONCILE_INTERVAL_SECONDS=30
INDEXING_CLEANUP_INTERVAL_SECONDS=300

# Vector DB
# VECTOR_DB_TYPE chooses the backend. Supported today:
#   * qdrant   — the default, optimized for large tenant fleets with
#                dedicated-process Qdrant (see
#                docs/zh-CN/design/qdrant_memory_optimization.md).
#   * pgvector — runs inside the existing ApeRAG PostgreSQL; pick this
#                for "ApeRAG-Lite / private delivery" where you want
#                one fewer component to operate. Switching backends is
#                a pure env flip; no schema migration is required
#                because each backend owns its own physical storage.
# Both backends honor the same VectorFilter DSL and tenant-guard
# semantics; see docs/zh-CN/design/vector_db_abstraction.md.
VECTOR_DB_TYPE=qdrant
# Qdrant connection coordinates. Chart v0.2.x hard-cut replaced the legacy
# ``VECTOR_DB_CONTEXT`` JSON-string env with discrete fields; ``QDRANT_URL`` /
# ``QDRANT_PORT`` / ``QDRANT_DISTANCE`` / ``QDRANT_TIMEOUT_SECONDS`` are read
# directly into ``settings.qdrant.*`` and assembled into the connector ctx
# by ``aperag.config.build_vector_db_context()``.
QDRANT_URL=http://127.0.0.1
QDRANT_PORT=6333
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT_SECONDS=1000

# ---- Qdrant multitenancy & memory optimization knobs ----
# Safe production defaults (see docs/zh-CN/design/qdrant_memory_optimization.md).
# QDRANT_MULTITENANT=False falls back to one-collection-per-tenant (legacy mode).
QDRANT_MULTITENANT=True
QDRANT_QUANTIZATION_ENABLED=True
QDRANT_QUANTIZATION_TYPE=int8
QDRANT_QUANTIZATION_QUANTILE=0.99
QDRANT_QUANTIZATION_ALWAYS_RAM=True
QDRANT_HNSW_ON_DISK=True
QDRANT_DEFAULT_SEGMENT_NUMBER=2
QDRANT_MMAP_THRESHOLD_KB=20480
QDRANT_VECTORS_ON_DISK=True
QDRANT_ON_DISK_PAYLOAD=True

# ---- pgvector knobs ----
# PGVECTOR_DATABASE_URL points at the Postgres that stores vectors.
# Leave empty to reuse the main ApeRAG Postgres (above POSTGRES_* /
# DATABASE_URL). Set to a dedicated DSN only when vector volume / QPS
# warrants isolation from the metadata DB.
# Examples:
#   PGVECTOR_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/aperag
# Required: the target database must have the ``vector`` extension
# installed (``CREATE EXTENSION vector`` — needs superuser on first run).
PGVECTOR_DATABASE_URL=
PGVECTOR_DB_POOL_SIZE=20
PGVECTOR_DB_POOL_MAX_OVERFLOW=40
PGVECTOR_DB_POOL_TIMEOUT=60
PGVECTOR_DB_POOL_RECYCLE=3600
PGVECTOR_DB_POOL_PRE_PING=True
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
PGVECTOR_HNSW_EF_SEARCH=40

# ---- Milvus knobs ----
# Only used when VECTOR_DB_TYPE=milvus. Leave MILVUS_URI empty unless the
# deployment explicitly enables Milvus; the connector fails loud instead of
# silently falling back to localhost.
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_DB_NAME=
MILVUS_MULTITENANT=True
MILVUS_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=64
MILVUS_HNSW_EF_SEARCH=40
MILVUS_TIMEOUT_SECONDS=30

# Elasticsearch
ES_HOST_NAME=127.0.0.1
ES_PORT=9200
ES_USER=
ES_PASSWORD=
ES_PROTOCOL=http
ES_HOST=
ES_TIMEOUT=30
ES_MAX_RETRIES=3
ES_FULLTEXT_NUMBER_OF_SHARDS=1
ES_FULLTEXT_NUMBER_OF_REPLICAS=0

# Auth
# JWT_SECRET MUST be set to a strong random string. The literal
# placeholder used to be ``SECRET`` here, which silently became the
# production signing key for any operator who copied this template
# verbatim. Generate one with:
#
#   openssl rand -hex 32
#
# Chart-driven deployments already fail to render when
# ``api.env.JWT_SECRET`` is empty.
JWT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
AUTH_TYPE=cookie
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTHING_DOMAIN=
AUTHING_APP_ID=
LOGTO_DOMAIN=
LOGTO_APP_ID=
REGISTER_MODE=unlimited

# Object Store
# OBJECT_STORE_TYPE can be "local" or "s3".
# "s3" is S3-API-compatible and works with MinIO, AWS S3, Alibaba Cloud
# OSS, Tencent COS, Huawei OBS — any service that speaks the S3 API.
# Switching backends is a pure env flip; just set the endpoint/credentials.
OBJECT_STORE_TYPE=local

# Options for OBJECT_STORE_TYPE=local
OBJECT_STORE_LOCAL_ROOT_DIR=.objects

# Options for OBJECT_STORE_TYPE=s3
OBJECT_STORE_S3_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORE_S3_REGION=
OBJECT_STORE_S3_ACCESS_KEY=minioadmin
OBJECT_STORE_S3_SECRET_KEY=minioadmin
OBJECT_STORE_S3_BUCKET=aperag
OBJECT_STORE_S3_PREFIX_PATH=
OBJECT_STORE_S3_USE_PATH_STYLE=True

DEBUG=False

MAX_BOT_COUNT=10
MAX_COLLECTION_COUNT=20
MAX_DOCUMENT_COUNT=4000
MAX_DOCUMENT_COUNT_PER_COLLECTION=200
MAX_DOCUMENT_SIZE=104857600

# P0-2 (perf-audit-v1 §2.3): defaults raised from 10/1 to 32/4 so a
# 5000-chunk long document doesn't run 500 sequential single-worker
# 10-chunk batches against the embedding provider. ~4x wall-clock
# reduction. Override back to MAX_WORKERS=1 if your embedder is a
# small self-hosted GPU (Ollama / vLLM with shared GPU).
EMBEDDING_MAX_CHUNKS_IN_BATCH=4
EMBEDDING_MAX_WORKERS=4

# Indexing per-lane concurrency caps (admin 8+8 PR-D — audit
# indexing-perf-audit-v1 §2.3 P1-4). Tune per LLM provider quota /
# GPU budget.
#
# 4 个 LLM 相关流水线（GRAPH_FACTS / GRAPH_VECTORS / SUMMARY /
# VISION）默认值 4 → 16 per indexing-concurrency-tuning-rfc.md §1.2
# (earayu2 msg=ca4113a5). 这一层是 OOM 防护栏，per-modality LLM
# 调用速率由新的 layer-3 Redis cap (默认 32 calls / modality 跨
# 所有 pod) 独立兜底.
INDEXING_VECTOR_CONCURRENCY=16
INDEXING_FULLTEXT_CONCURRENCY=32
INDEXING_GRAPH_CONCURRENCY=4
INDEXING_GRAPH_FACTS_CONCURRENCY=16
INDEXING_GRAPH_VECTORS_CONCURRENCY=16
INDEXING_SUMMARY_CONCURRENCY=16
INDEXING_VISION_CONCURRENCY=16
INDEXING_PARSE_CONCURRENCY=8

TIKTOKEN_CACHE_DIR=.cache/tiktoken
DEFAULT_ENCODING_MODEL=cl100k_base
TOKENIZERS_PARALLELISM=false

# ---- Graph DB backend (aperag/graphindex) ----
# GRAPH_DB_TYPE chooses the graph storage backend. Supported:
#   * postgresql — default, reuses the main ApeRAG Postgres. Zero extra
#     components to deploy.
#   * neo4j     — set NEO4J_URI / NEO4J_USERNAME / NEO4J_PASSWORD.
#   * nebula    — set NEBULA_HOSTS / NEBULA_USERNAME / NEBULA_PASSWORD.
# Switching backends is a pure env flip. The graph store abstraction
# (GraphStore Protocol) guarantees identical semantics regardless of
# backend; see docs/zh-CN/design/graphindex_rewrite.md.
GRAPH_DB_TYPE=postgresql
# Optional dedicated PostgreSQL URL for graph_storage. Leave empty to reuse
# DATABASE_URL (same cluster as metadata PG). Set when you want an
# independent PG cluster for graph data isolation / connection pool tuning.
# Example: postgresql://postgres:password@127.0.0.1:5433/postgres
GRAPH_DATABASE_URL=
# Graph PG connection pool knobs (only effective when GRAPH_DATABASE_URL is
# set to a dedicated cluster). See deploy/aperag/values.yaml api.graphPool.
# GRAPH_DB_POOL_SIZE=20
# GRAPH_DB_POOL_MAX_OVERFLOW=40
# GRAPH_DB_POOL_TIMEOUT=60
# GRAPH_DB_POOL_RECYCLE=3600
# GRAPH_DB_POOL_PRE_PING=True
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEBULA_HOSTS=
NEBULA_USERNAME=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE_PREFIX=aperag

# ---- Document cross-reference graph ----
# Background feature: builds document-to-document relationship edges from
# co-cited entities (via the reconciler loop). Default off.
# Set APERAG_DOC_GRAPH_ENABLED=true to opt a deployment into doc-graph indexing.
APERAG_DOC_GRAPH_ENABLED=False
APERAG_DOC_GRAPH_MAX_DOCS_PER_COLLECTION=1000
APERAG_DOC_GRAPH_MAX_EDGES_PER_COLLECTION=20000
APERAG_DOC_GRAPH_MAX_PAIRS_PER_RUN=2000
APERAG_DOC_GRAPH_STALE_COOLDOWN_SECONDS=86400
APERAG_DOC_GRAPH_SQL_TIMEOUT_SECONDS=30

# ---- Chat title backfill loop ----
# Indexing worker runs a background loop generating titles for untitled chats.
# Set interval to 0 to disable. Lower the interval for faster title coverage
# at higher LLM cost.
CHAT_TITLE_BACKFILL_INTERVAL_SECONDS=3600
CHAT_TITLE_BACKFILL_MAX_CHATS_PER_ITERATION=100

CACHE_ENABLED=True
CACHE_TTL=86400
CACHE_REDIS_URL=
CACHE_LLM_TTL_SECONDS=
CACHE_EMBEDDING_TTL_SECONDS=
CACHE_WEB_SEARCH_TTL_SECONDS=600
CACHE_WEB_READ_TTL_SECONDS=3600
CACHE_PARSER_PREFLIGHT_TTL_SECONDS=60
CACHE_REMOTE_PARSER_TTL_SECONDS=604800
CACHE_MAX_VALUE_BYTES=8388608
READ_PRIMITIVE_CACHE_L1_SIZE=256
READ_PRIMITIVE_CACHE_L2_TTL_SECONDS=3600

# Admin 8+8 PR2.5b hard cut: LLM_KEYWORD_EXTRACTION_PROVIDER /
# LLM_KEYWORD_EXTRACTION_MODEL env vars are removed. Bind a
# model to the KEYWORD_EXTRACTION ModelUseScenario via the
# /admin/configuration model_use card (PR #65 / PR #77).

# Optional parser integrations
WHISPER_HOST=
PADDLEOCR_HOST=

# Observability
APERAG_OBSERVABILITY_MODE=local
APERAG_OBSERVABILITY_LOG_FORMAT=json
APERAG_OBSERVABILITY_CAPTURE_CONTENT=False
APERAG_OBSERVABILITY_SAMPLE_RATIO=1.0
# Recent errors aggregation backend (PR #366). "redis" aggregates errors
# across all api pod replicas into a shared ring buffer (recommended for
# multi-replica). "memory" = per-pod only (suitable for single-process dev).
APERAG_OBSERVABILITY_RECENT_ERRORS_BACKEND=redis
# Legacy switch kept for compatibility. Prefer APERAG_OBSERVABILITY_MODE.
OTEL_ENABLED=
OTEL_SERVICE_NAME=aperag
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=development
OTEL_RESOURCE_ATTRIBUTES=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_CONSOLE_ENABLED=False
OTEL_FASTAPI_ENABLED=True
OTEL_SQLALCHEMY_ENABLED=True
OTEL_MCP_ENABLED=True

# ApeRAG agent runtime 内部 MCP server URL（docker compose 必须设为 api 服务名）
# 默认 localhost:8000 在 indexing-worker 容器内连不到 api，会导致 agent chat ConnectError
APERAG_MCP_URL=http://api:8000/mcp/
